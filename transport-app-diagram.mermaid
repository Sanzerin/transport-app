graph TD
    APP["ТрансЛогистик — React SPA"]

    APP --> NAV["Навигация и роутинг через useState"]

    NAV --> CLIENT["Клиентский модуль"]
    NAV --> ADMIN["Административный модуль"]
    NAV --> DRIVER["Модуль водителя"]

    CLIENT --> C1["Мои заказы — история, статусы, поиск, фильтрация"]
    CLIENT --> C2["Калькулятор — расчёт стоимости по тарифу"]
    CLIENT --> C3["Новая заявка — форма с валидацией"]
    CLIENT --> C4["Уведомления — статусы и оплата"]

    ADMIN --> A1["Дашборд — метрики, график выручки, доставляемость"]
    ADMIN --> A2["Управление заявками — редактирование, удаление, смена статуса"]
    ADMIN --> A3["Транспорт — карточки ТС, топливо, пробег"]
    ADMIN --> A4["Водители — рейтинг, рейсы, статус"]
    ADMIN --> A5["Тарифы — редактирование цен и условий"]

    DRIVER --> D1["Задания — приём, подтверждение, отметка доставки"]
    DRIVER --> D2["Чат с диспетчером — обмен сообщениями"]
    DRIVER --> D3["Путевой лист — просмотр и подпись"]
    DRIVER --> D4["Навигация — маршрут, расстояние, время"]

    C1 & A1 & A2 & D1 --> ORDERS[("Заказы")]
    C2 & A5 --> TARIFFS[("Тарифы")]
    A3 --> VEHICLES[("Транспорт")]
    A4 --> DRIVERSDATA[("Водители")]
    D2 --> MESSAGES[("Сообщения")]

    ORDERS --> LS["localStorage — сохранение между сессиями"]
    TARIFFS --> LS
    VEHICLES --> LS
    DRIVERSDATA --> LS
    MESSAGES --> LS

    UI["Общие компоненты: Card, Button, Table, Modal, Toast, TabBar, StatusBadge"]
    APP -.-> UI
